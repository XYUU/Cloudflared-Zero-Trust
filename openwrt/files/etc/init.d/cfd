#!/bin/sh /etc/rc.common
# SPDX-License-Identifier: Apache-2.0
#
# procd init script for cfd on OpenWrt / 光猫 firmware.
#
# Reads /etc/config/cfd (UCI):
#   config cfd 'main'
#       option enabled '1'
#       option config '/etc/cfd.ini'
#       option verbose '0'
#
# procd restarts on crash, captures stdout/stderr to logd, and tears the
# process down cleanly on reboot. We do NOT background cfd ourselves --
# procd's `setpid` handles that.

# shellcheck disable=SC2034
START=99
USE_PROCD=1

PROG=/usr/sbin/cfd

start_service() {
    config_load 'cfd'

    # shellcheck disable=SC3043
    local enabled config verbose
    config_get_bool enabled main enabled 1
    config_get      config  main config  '/etc/cfd.ini'
    config_get_bool verbose main verbose 0

    [ "$enabled" = "1" ] || return 0
    [ -x "$PROG" ]       || { logger -t cfd "missing $PROG"; return 1; }
    [ -r "$config" ]     || { logger -t cfd "missing config $config"; return 1; }

    procd_open_instance
    procd_set_param command "$PROG" --config "$config"
    [ "$verbose" = "1" ] && procd_append_param command --verbose

    # Crash policy: at most 5 restarts in 60s, then give up so we don't
    # thrash the flash. Reboot to recover.
    procd_set_param respawn 60 5 0

    procd_set_param stdout 1
    procd_set_param stderr 1

    # cfd needs CAP_NET_ADMIN (TUN + RTNETLINK). Easiest path on OpenWrt is
    # to just run as root; the binary is tiny and audited.
    procd_set_param user root

    procd_set_param limits core="unlimited"
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger 'cfd'
}

reload_service() {
    stop
    start
}
